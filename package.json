{
  "name": "shulex-official-chatbot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "yarn gen-alts && NODE_OPTIONS=--max_old_space_size=4096 next dev --port 3002",
    "build": "next build",
    "start": "mkdir -p ./logs/ && next start -p 3000 > ./logs/master-stdout.log",
    "lint": "next lint",
    "analyze": "ANALYZE=true next build",
    "svgr": "svgr --icon=100% --typescript --out-dir ./src/components/Icons/ --ignore-existing -- ./public/svg",
    "gen-alts": "node ./scripts/alternative.js",
    "predev": "ts-node --project ./tsconfig.node.json ./scripts/genAntdCss.tsx",
    "prebuild": "cross-env NODE_ENV=production ts-node --project ./tsconfig.node.json ./scripts/genAntdCss.tsx"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@emotion/react": "^11.10.6",
    "@emotion/styled": "^11.10.6",
    "@glidejs/glide": "^3.6.0",
    "@mui/material": "^5.11.9",
    "@next/font": "^14.2.15",
    "@react-hook/resize-observer": "^1.2.6",
    "@twilio/voice-sdk": "^2.18.0",
    "@types/node": "18.11.18",
    "@types/react": "18.0.27",
    "@types/react-dom": "18.0.10",
    "@vapi-ai/web": "^2.3.10",
    "ahooks": "^3.7.8",
    "antd": "^5.0.0",
    "aos": "^2.3.4",
    "axios": "^1.7.9",
    "big.js": "^6.2.1",
    "classnames": "^2.3.2",
    "compare-versions": "^6.1.0",
    "dayjs": "^1.11.7",
    "express": "^4.18.2",
    "http-proxy-middleware": "^2.0.6",
    "linkedom": "^0.18.11",
    "localforage": "^1.10.0",
    "lodash": "^4.17.21",
    "lottie-web": "^5.13.0",
    "markdown-to-jsx": "^7.7.4",
    "next": "14.2.28",
    "next-with-less": "^3.0.1",
    "querystring": "^0.2.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-markdown": "^8.0.7",
    "react-router-dom": "^6.8.0",
    "react-sortable-hoc": "^2.0.0",
    "recoil": "^0.7.7",
    "rehype-raw": "^7.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sha256": "^0.2.0",
    "shulex-util": "^1.1.17",
    "simplex-noise": "3.0.1",
    "typed.js": "^2.1.0",
    "typescript": "4.9.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@ant-design/static-style-extract": "^1.0.1",
    "@next/bundle-analyzer": "^13.4.2",
    "@svgr/cli": "^6.5.1",
    "@types/big.js": "^6.1.6",
    "@types/lodash": "^4.14.191",
    "@types/sha256": "^0.2.0",
    "autoprefixer": "^10.4.16",
    "babel-plugin-import": "^1.13.6",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "eslint": "8.33.0",
    "eslint-config-next": "14.2.28",
    "less": "^4.1.3",
    "less-loader": "^11.1.0",
    "next-compose-plugins": "^2.2.1",
    "next-sitemap": "^4.2.3",
    "next-transpile-modules": "^10.0.0",
    "node-fetch": "2",
    "path": "^0.12.7",
    "postcss": "^8.4.31",
    "postcss-pxtorem": "^6.0.0",
    "react-countdown-now": "^2.1.2",
    "sass": "^1.86.3",
    "style-loader": "^4.0.0",
    "ts-node": "^10.9.1",
    "tslib": "^2.5.3",
    "worker-loader": "^3.0.8"
  }
}
